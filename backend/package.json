    "express": "^4.21.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "json-rules-engine": "^7.3.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "mongoose": "^8.6.0",
    "nanoid": "^5.0.7",
    "pg": "^8.12.0",
